            "bold": true
        },
        "class": {
            "foreground": "#FF4FA3",
            "bold": true
        },
        "class.declaration": {
            "foreground": "#FF4FA3",
            "bold": true
        },
        "struct": {
            "foreground": "#FF4FA3",
            "bold": true
