        "interface": {
            "foreground": "#FF4FA3",
            "bold": true
        },
        "enum": {
            "foreground": "#FF4FA3",
            "bold": true
        },
        "typeParameter": "#FF9FD0",
        "function": "#00D26A",
        "function.declaration": {
            "foreground": "#00D26A",
            "bold": true
        },
        "method": "#00D26A",
        "method.declaration": {
            "foreground": "#00D26A",
            "bold": true
        },
        "macro": {
            "foreground": "#00D26A",
            "bold": true
        },
        "variable": "#E8EAF6",
        "variable.readonly": "#FF9FD0",
        "variable.defaultLibrary": "#FF9FD0",
        "parameter": "#FF9FD0",
        "property": "#18E87D",
        "property.readonly": "#18E87D",
        "enumMember": "#18E87D",
        "event": "#18E87D",
        "decorator": {
            "foreground": "#FF4FA3",
            "bold": true
        },
        "label": "#FF4FA3",
        "keyword": "#FF7ABC",
        "modifier": "#FF7ABC",
        "operator": "#FF7ABC",
        "comment": {
            "foreground": "#7A7F9A",
            "italic": true
        },
        "string": "#00D26A",
        "number": "#18E87D",
        "regexp": "#18E87D",
        "decorator:python": {
            "foreground": "#FF4FA3",
            "bold": true
        },
        "selfParameter:python": "#FF9FD0",
        "clsParameter:python": "#FF9FD0"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7A7F9A",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Invalid / illegal",
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#FFFFFF",
                "background": "#FF4FA3"
            }
        },
        {
            "name": "Keywords / storage / control",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.logical",
                "keyword.operator.expression",
                "storage",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#FF7ABC"
            }
        },
        {
            "name": "Operators / punctuation accents",
            "scope": [
                "keyword.operator",
                "punctuation.separator.key-value",
                "punctuation.definition.template-expression",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#FF7ABC"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.unquoted"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "String escapes / interpolation",
            "scope": [
                "constant.character.escape",
                "constant.character.format.placeholder",
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "meta.template.expression"
            ],
            "settings": {
                "foreground": "#FF9FD0"
            }
        },
        {
            "name": "Numbers / booleans / constants",
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.other",
                "variable.language",
                "support.constant"
            ],
            "settings": {
                "foreground": "#18E87D"
            }
        },
        {
            "name": "Functions",
            "scope": [
                "entity.name.function",
                "meta.function-call entity.name.function",
                "support.function",
                "support.function.builtin"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "Classes / types / constructors",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.type.class",
                "entity.name.type.interface",
                "entity.name.type.enum",
                "support.class",
                "support.type",
                "support.type.primitive",
                "support.type.builtin"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Namespaces / modules / imports",
            "scope": [
                "entity.name.namespace",
                "entity.name.scope-resolution",
                "support.module",
                "variable.other.module",
                "meta.import"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#E8EAF6"
            }
        },
        {
            "name": "Parameters",
            "scope": [
                "variable.parameter",
                "meta.function.parameters variable",
                "meta.parameters variable"
            ],
            "settings": {
                "foreground": "#FF9FD0"
            }
        },
        {
            "name": "Properties / object keys",
            "scope": [
                "variable.other.property",
                "support.variable.property",
                "support.type.property-name",
                "meta.property-name",
                "meta.object-literal.key",
                "meta.object.member",
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#18E87D"
            }
        },
        {
            "name": "Decorators / annotations",
            "scope": [
                "meta.decorator",
                "entity.name.function.decorator",
                "punctuation.decorator",
                "storage.type.annotation"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Python classes / exceptions",
            "scope": [
                "entity.name.type.class.python",
                "support.class.python",
                "support.type.exception.python",
                "entity.name.type.exception.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Python functions / methods",
            "scope": [
                "entity.name.function.python",
                "meta.function-call.generic.python entity.name.function.python",
                "support.function.python"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "Python parameters / self",
            "scope": [
                "variable.parameter.function.python",
                "meta.function.parameters.python variable.parameter.python",
                "variable.parameter.python"
            ],
            "settings": {
                "foreground": "#FF9FD0"
            }
        },
        {
            "name": "Python properties / magic",
            "scope": [
                "variable.other.property.python",
                "meta.member.access.python",
                "support.variable.magic.python"
            ],
            "settings": {
                "foreground": "#18E87D"
            }
        },
        {
            "name": "JS/TS keywords",
            "scope": [
                "keyword.control.js",
                "keyword.control.ts",
                "keyword.control.jsx",
                "keyword.control.tsx",
                "keyword.operator.expression.js",
                "keyword.operator.expression.ts",
                "storage.type.js",
                "storage.type.ts",
                "storage.modifier.js",
                "storage.modifier.ts"
            ],
            "settings": {
                "foreground": "#FF7ABC"
            }
        },
        {
            "name": "JS/TS functions",
            "scope": [
                "entity.name.function.js",
                "entity.name.function.ts",
                "entity.name.function.jsx",
                "entity.name.function.tsx",
                "support.function.dom.js",
                "support.function.dom.ts"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
