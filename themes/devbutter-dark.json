    "tokenColors": [
        {
            "name": "Base text",
            "scope": [
                "source",
                "text",
                "meta.embedded"
            ],
            "settings": {
                "foreground": "#FFFFFF"
            }
        },
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#F8A0B6",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Documentation comments",
            "scope": [
                "comment.block.documentation",
                "string.quoted.docstring",
                "source.python string.quoted.docstring"
            ],
            "settings": {
                "foreground": "#F8A0B6",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.control.import",
                "keyword.control.from",
                "keyword.control.flow",
                "keyword.control.conditional",
                "keyword.control.loop",
                "keyword.control.trycatch",
                "keyword.other.phpdoc"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "Declaration keywords",
            "scope": [
                "storage.type",
                "storage.modifier",
                "keyword.declaration",
                "keyword.other.class",
                "storage.type.class",
                "keyword.other.function",
                "storage.type.function"
            ],
            "settings": {
                "foreground": "#F64C6F"
            }
        },
        {
            "name": "Operators and punctuation",
            "scope": [
                "keyword.operator",
                "punctuation",
                "punctuation.separator",
                "punctuation.terminator",
                "meta.brace",
                "meta.delimiter"
            ],
            "settings": {
                "foreground": "#F8A0B6"
            }
        },
        {
            "name": "Constants and numbers",
            "scope": [
                "constant",
                "constant.language",
                "constant.numeric",
                "constant.character",
                "constant.other"
            ],
            "settings": {
                "foreground": "#F8A0B6"
            }
        },
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "String escapes",
            "scope": [
                "constant.character.escape",
                "constant.other.placeholder",
                "punctuation.definition.template-expression"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "Functions and methods",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call",
                "variable.function",
                "entity.name.function.member"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "Classes, structs, interfaces and types",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.struct",
                "entity.name.interface",
                "entity.name.enum",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#28B1BE",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "meta.definition.variable.name",
                "entity.name.variable",
                "variable.other.readwrite",
                "variable.other.object"
            ],
            "settings": {
                "foreground": "#79E59B",
            }
        },
        {
            "name": "Parameters",
            "scope": [
                "variable.parameter",
                "meta.parameter",
                "meta.function.parameters",
                "variable.parameter.function",
                "variable.parameter.function.swift",
                "variable.parameter.function-call",
                "meta.argument",
                "meta.arguments"
            ],
            "settings": {
                "foreground": "#28B1BE"
            }
        },
        {
            "name": "Properties and fields",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "support.variable.property",
                "meta.object-literal.key",
                "meta.property-name"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "Decorators and annotations",
            "scope": [
                "meta.decorator",
                "entity.name.function.decorator",
                "punctuation.definition.decorator",
                "storage.type.annotation"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "Imports and modules",
            "scope": [
                "entity.name.namespace",
                "support.module",
                "meta.import variable.other.readwrite",
                "meta.import entity.name"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "JSON keys and quotes",
            "scope": [
                "support.type.property-name.json",
                "support.type.property-name.json.comments",
                "meta.structure.dictionary.key.json string.quoted.double.json",
                "meta.structure.dictionary.key.json punctuation.definition.string.begin.json",
                "meta.structure.dictionary.key.json punctuation.definition.string.end.json"
            ],
            "settings": {
                "foreground": "#F8A0B6"
            }
        },
        {
            "name": "JSON string values and quotes",
            "scope": [
                "source.json meta.structure.dictionary.value.json string.quoted.double.json",
                "source.json.comments meta.structure.dictionary.value.json string.quoted.double.json",
                "source.json meta.structure.array.json string.quoted.double.json",
                "source.json meta.structure.dictionary.value.json punctuation.definition.string.begin.json",
                "source.json meta.structure.dictionary.value.json punctuation.definition.string.end.json",
                "source.json meta.structure.array.json punctuation.definition.string.begin.json",
                "source.json meta.structure.array.json punctuation.definition.string.end.json"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "JSON punctuation",
            "scope": [
                "punctuation.separator.dictionary.key-value.json",
                "punctuation.separator.dictionary.pair.json",
                "punctuation.definition.dictionary.begin.json",
                "punctuation.definition.dictionary.end.json",
                "punctuation.definition.array.begin.json",
                "punctuation.definition.array.end.json"
            ],
            "settings": {
                "foreground": "#F8A0B6"
            }
        },
        {
            "name": "HTML/XML tags",
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag",
                "meta.tag",
                "meta.tag.structure",
                "text.html entity.name.tag",
                "text.xml entity.name.tag"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "HTML/XML attributes",
            "scope": [
                "entity.other.attribute-name",
                "text.html entity.other.attribute-name",
                "text.xml entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "HTML entities",
            "scope": [
                "constant.character.entity",
                "punctuation.definition.entity"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "CSS selectors",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css",
                "entity.name.tag.css",
                "meta.selector.css",
                "meta.selector.scss"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "CSS properties",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.scss",
                "meta.property-name.css",
                "meta.property-name.scss"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "CSS values",
            "scope": [
                "support.constant.property-value.css",
                "support.constant.property-value.scss",
                "support.constant.color",
                "constant.other.color",
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "CSS functions and variables",
            "scope": [
                "support.function.misc.css",
                "support.function.misc.scss",
                "variable.scss",
                "variable.css"
            ],
            "settings": {
                "foreground": "#79E59B"
            }
        },
        {
            "name": "JS/TS this and super",
            "scope": [
                "variable.language.this",
                "variable.language.super",
                "variable.language.import-meta"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "JSX/TSX components",
            "scope": [
                "support.class.component",
                "entity.name.tag.jsx",
                "entity.name.tag.tsx"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "JSX/TSX attributes",
            "scope": [
                "entity.other.attribute-name.jsx",
                "entity.other.attribute-name.tsx"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "Python builtins and self",
            "scope": [
                "support.function.builtin.python",
                "support.type.python",
                "variable.language.special.self.python",
                "constant.language.python"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "PHP variables and tags",
            "scope": [
                "variable.other.php",
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
            ],
            "settings": {
                "foreground": "#79E59B"
            }
        },
        {
            "name": "Swift attributes and labels",
            "scope": [
                "storage.modifier.attribute.swift",
                "entity.name.function.swift",
                "entity.name.type.swift",
                "variable.parameter.function.swift"
            ],
            "settings": {
                "foreground": "#28B1BE"
            }
        },
        {
            "name": "Markdown headings",
            "scope": [
                "markup.heading",
                "entity.name.section.markdown",
                "punctuation.definition.heading.markdown"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Markdown emphasis",
            "scope": [
                "markup.bold",
                "punctuation.definition.bold.markdown",
                "markup.italic",
                "punctuation.definition.italic.markdown"
            ],
            "settings": {
                "foreground": "#F8A0B6"
            }
        },
        {
            "name": "Markdown links",
            "scope": [
                "markup.underline.link",
                "string.other.link",
                "meta.link.inline.markdown"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "name": "Markdown code",
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code.block",
                "markup.raw.block.markdown"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "Markdown quotes and lists",
            "scope": [
                "markup.quote",
                "punctuation.definition.quote.begin.markdown",
                "beginning.punctuation.definition.list.markdown"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "YAML keys",
            "scope": [
                "entity.name.tag.yaml",
                "support.type.property-name.yaml"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "YAML anchors",
            "scope": [
                "entity.name.type.anchor.yaml",
                "variable.other.alias.yaml"
            ],
            "settings": {
                "foreground": "#FF4FA3"
            }
        },
        {
            "name": "TOML and INI sections",
            "scope": [
                "entity.name.section.toml",
                "meta.table.toml",
                "entity.name.section.group-title.ini"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "name": "TOML, INI and ENV keys",
            "scope": [
                "support.type.property-name.toml",
                "variable.other.key.toml",
                "keyword.other.definition.ini",
                "variable.other.assignment.ini",
                "variable.other.env",
                "variable.other.assignment.env"
            ],
            "settings": {
                "foreground": "#70E1EC"
            }
        },
        {
            "name": "Config punctuation",
