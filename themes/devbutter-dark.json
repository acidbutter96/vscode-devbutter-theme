            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Python decorators",
            "scope": [
                "source.python meta.decorator.python",
                "source.python meta.function.decorator.python",
                "source.python entity.name.function.decorator.python",
                "source.python meta.decorator.python entity.name.function.python",
                "source.python meta.decorator.python entity.name.type.python",
                "source.python meta.decorator.python variable.other.readwrite.python",
                "source.python meta.decorator.python variable.other.property.python",
                "source.python meta.decorator.python support.function.python",
                "source.python meta.decorator.python support.class.python",
                "meta.decorator.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Python functions and methods",
            "scope": [
                "source.python entity.name.function.python",
                "source.python entity.name.function.member.python",
                "source.python meta.function.python entity.name.function.python",
                "source.python meta.function-call.python entity.name.function.python",
                "source.python meta.function-call.python variable.function.python",
                "source.python support.function.builtin.python"
            ],
            "settings": {
                "foreground": "#70E1EC",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Python magic methods",
            "scope": [
                "source.python entity.name.function.magic.python",
                "source.python support.function.magic.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
