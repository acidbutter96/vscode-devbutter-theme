    "tokenColors": [
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7D6472",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Documentation comments",
            "scope": [
                "comment.block.documentation",
                "string.quoted.docstring",
                "source.python string.quoted.docstring"
            ],
            "settings": {
                "foreground": "#7D6472",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Python async and control flow",
            "scope": [
                "source.python keyword.control.flow.python",
                "source.python keyword.control.return.python",
                "source.python keyword.control.yield.python",
                "source.python storage.modifier.async.python",
                "source.python storage.modifier.async",
                "source.python keyword.control.await.python",
                "source.python keyword.control.raise.python",
                "source.python keyword.control.exception.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Python declaration keywords",
            "scope": [
                "source.python storage.type.function.python",
                "source.python storage.type.class.python",
                "source.python keyword.declaration.function.python",
                "source.python keyword.declaration.class.python",
                "source.python keyword.other.class",
                "source.python keyword.other.function"
            ],
            "settings": {
                "foreground": "#79E59B",
                "fontStyle": ""
            }
        },
        {
            "name": "Python decorator punctuation",
