    "tokenColors": [
        {
            "scope": [
                "entity.name.type.class.python",
                "support.class.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "meta.function.decorator.python",
                "entity.name.function.decorator.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
