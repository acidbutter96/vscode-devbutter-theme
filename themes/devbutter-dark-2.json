                "entity.name.type.exception.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.control.python",
                "keyword.operator.logical.python",
                "keyword.operator.assignment.python",
                "storage.type.function.python",
                "storage.type.class.python",
                "storage.modifier.declaration.python"
            ],
            "settings": {
                "foreground": "#FF7ABC"
            }
        },
        {
            "scope": [
                "entity.name.function.python",
                "meta.function-call.generic.python entity.name.function.python",
                "support.function.python"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "scope": [
                "variable.other.readwrite.python",
                "variable.other.object.python"
            ],
            "settings": {
                "foreground": "#E8EAF6"
            }
        },
        {
            "scope": [
                "variable.parameter.function.python",
                "meta.function.parameters.python variable.parameter.python"
            ],
            "settings": {
                "foreground": "#FF9FD0"
            }
        },
        {
            "scope": [
                "variable.other.property.python",
                "meta.member.access.python",
                "support.variable.magic.python"
            ],
            "settings": {
                "foreground": "#18E87D"
            }
        },
        {
            "scope": [
                "support.type.python",
                "support.type.exception.python"
            ],
            "settings": {
                "foreground": "#FF4FA3",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "support.module.python",
                "variable.other.module.python"
            ],
            "settings": {
                "foreground": "#00D26A"
            }
        },
        {
            "scope": [
